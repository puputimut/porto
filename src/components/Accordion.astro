---
interface Props {
  title?: string;
}

const { title = "More Details" } = Astro.props;
---

<div class="mb-4 border-b border-neutral/20 pb-4 bg-pink-200 p-6 rounded-xl">
  <details class="group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
    <summary class="flex list-none items-center justify-between font-serif text-xl font-medium text-slate-900 transition-colors hover:text-primary">
      <span>
        {title}
      </span>

      <span class="transition-transform duration-300 group-open:-rotate-180 text-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m6 9 6 6 6-6"/>
        </svg>
      </span>
    </summary>

    <div class="mt-4 text-slate-900 leading-relaxed">
      <slot />
    </div>
  </details>
</div>