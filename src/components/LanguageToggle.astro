---
const pathname = Astro.url.pathname;
const isId = pathname.startsWith('/id');
const targetUrl = isId ? '/' : '/id/';
const langText = isId ? 'ID' : 'EN';
---

<a
  href={targetUrl}
  class="flex h-9 w-9 items-center justify-center rounded-full border border-neutral/20 bg-black text-sm font-medium text-slate-900 transition-all hover:border-primary hover:text-primary"
>
  {langText}
</a>