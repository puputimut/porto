---
import Accordion from "./Accordion.astro";
import Section from "./Section.astro";
import type { ExperienceProps } from "@types";

interface Props {
  experience: ExperienceProps[];
}

const { experience } = Astro.props;
---

<Section text="Experience" href="experience">
  {
    experience.map(({ company, position, startDate, endDate, summary }) => (
      <div class="mb-10 border-b border-neutral/10 pb-10 last:border-0">
        <h3 class="mb-1.5 font-serif text-2xl font-semibold text-white">
          {company}
        </h3>
        <div class="flex flex-col items-start pb-5">
          <h4 class="mb-0.5 font-serif text-2xl font-medium text-primary">
            {position}
          </h4>
          <span class="pb-[2px] text-sm text-white/70">
            {startDate} — {endDate}
          </span>
        </div>

        {/* This replaces your old list/paragraph logic */}
        <Accordion 
          title="Detail Selengkapnya" 
          content={Array.isArray(summary) ? summary.join(". ") : summary} 
        />
      </div>
    ))
  }
</Section>