---
import Accordion from "./Accordion.astro";
import Section from "./Section.astro";
import type { ExperienceProps } from "@types";

interface Props {
  experience: ExperienceProps[];
}

const { experience } = Astro.props;

// Detect language for the section title
const pathname = Astro.url.pathname;
const isId = pathname.startsWith('/id');
const sectionTitle = isId ? "Pengalaman" : "Experience";
---

<Section text={sectionTitle} href="experience">
  {
    experience.map(({ company, position, startDate, endDate, summary }) => (
      <div class="mb-10 border-b border-neutral/20 pb-10 last:border-0">
        <h3 class="mb-1.5 font-serif text-2xl font-semibold text-slate-900">
          {company}
        </h3>
        <div class="flex flex-col items-start pb-5">
          <h4 class="mb-0.5 font-serif text-2xl font-medium text-primary">
            {position}
          </h4>
          <span class="pb-[2px] text-sm text-slate-900/70">
            {startDate} — {endDate}
          </span>
        </div>

        <Accordion>
          {Array.isArray(summary) ? (
            <ul class="list-none">
              {summary.map((log) => (
                <li class="relative mb-3 pl-8 text-base text-slate-700 before:absolute before:top-1 before:left-0 before:content-[url(/check.svg)]">
                  {log}
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-base text-slate-700">{summary}</p>
          )}
        </Accordion>
      </div>
    ))
  }
</Section>